  "fieldNotes": {
    "action": {
      "zhNote": "ERP 动作名称",
      "enNote": "ERP action name. It decides which ERP operation will be executed."
    },
    "ecafeToken": {
      "zhNote": "登录后返回的 token",
      "enNote": "Authentication token returned by the login interface."
    },
    "relationInfoId": {
      "zhNote": "ERP 批次关系 ID",
      "enNote": "ERP batch relation ID used by PDA to identify the current production batch."
    },
    "batch": {
      "zhNote": "生产批次号",
      "enNote": "Production batch number selected by the PDA user."
    },
    "operationTypeCode": {
      "zhNote": "操作类型",
      "enNote": "Operation type code, such as overallFeed, directFeed, or premixFeed."
    },
    "serialNumber": {
      "zhNote": "当前锅次/作业序号",
      "enNote": "Current work serial number used for recovery, validation, and submission."
    },
    "traceCode": {
      "zhNote": "完整二维码原文",
      "enNote": "Full original QR code content scanned by PDA."
    },
    "businessVarietyId": {
      "zhNote": "物料 ID",
      "enNote": "Material ID. It must match a material in the current formula list."
    },
    "weight": {
      "zhNote": "二维码重量",
      "enNote": "Weight encoded in the QR code."
    },
    "num": {
      "zhNote": "提交明细中的投料重量",
      "enNote": "Submitted launch weight for the material detail item."
    },
    "unitName": {
      "zhNote": "重量单位",
      "enNote": "Weight unit, for example kg."
    },
    "inventoryBatch": {
      "zhNote": "库存批号",
      "enNote": "Inventory batch number from the QR code or launch detail."
    },
    "productionDate": {
      "zhNote": "生产日期",
      "enNote": "Production date of the inventory batch."
    },
    "produceDate": {
      "zhNote": "生产日期兼容别名",
      "enNote": "Compatible alias of productionDate when parsing QR code content."
    },
    "validDate": {
      "zhNote": "有效期",
      "enNote": "Expiration date of the inventory batch."
    },
    "belongProduceBatch": {
      "zhNote": "二维码所属生产批次",
      "enNote": "Production batch number encoded in the QR code."
    },
    "outputProductId": {
      "zhNote": "产出品 ID",
      "enNote": "Output product ID of the selected production batch."
    },
    "operationDate": {
      "zhNote": "PDA 操作时间",
      "enNote": "PDA operation time."
    },
    "launchDetailJson": {
      "zhNote": "投料明细 JSON 字符串数组",
      "enNote": "Stringified JSON array of material launch detail items."
    },
    "codeContentsJson": {
      "zhNote": "扫码内容 JSON 字符串数组",
      "enNote": "Stringified JSON array of scanned QR code records."
    },
    "scanTimestamp": {
      "zhNote": "扫码时间戳",
      "enNote": "PDA scan timestamp in milliseconds."
    },
    "scanTime": {
      "zhNote": "格式化扫码时间",
      "enNote": "Formatted PDA scan time for ERP logs."
    },
    "receiptId": {
      "zhNote": "ERP 回执 ID",
      "enNote": "ERP receipt ID returned after saving launch records."
    },
    "clientStatus": {
      "zhNote": "PDA 回执确认状态",
      "enNote": "PDA acknowledgement status, usually ACKED."
    }
  }
}
