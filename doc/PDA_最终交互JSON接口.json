{
  "documentName": "PDA final interaction JSON interface specification",
  "version": "1.0",
  "language": "zh-CN",
  "scope": "Only describes the final JSON interaction payloads between PDA and ERP/mock server. No source code behavior is changed by this file.",
  "importantNotes": [
    {
      "note": "In the Android project, most ERP requests are sent as form fields. This file expresses the same payloads as JSON for interface review and ERP alignment."
    },
    {
      "note": "launchDetailJson and codeContentsJson are stringified JSON arrays in the real request body."
    },
    {
      "note": "traceCode should keep the full original QR code content. PDA should not rebuild or shorten it before sending."
    },
    {
      "note": "productionDate is the preferred field name. produceDate is only a compatible alias when parsing QR code content."
    }
  ],
  "flow": [


